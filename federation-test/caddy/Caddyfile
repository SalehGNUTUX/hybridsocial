# Federation testbed Caddyfile.
#
# Four sites, all with auto Let's Encrypt:
#   * arab.place                   → HybridSocial main app
#   * media.arab.place             → HybridSocial user-upload origin
#   * mastodon.arab.place          → Mastodon main app
#   * media-mastodon.arab.place    → (reserved; Mastodon serves its
#                                    own media off the main host but
#                                    cert is provisioned for future
#                                    when we move to S3-backed media)
#
# All must be publicly resolvable for ACME to succeed and for the
# instances to fetch each other's actor JSON.

{
	email {$ACME_EMAIL}

	# Disable HTTP/3. Mobile Chrome upgrades to QUIC after seeing
	# alt-svc but on this network the streams reset
	# (`H3_REQUEST_CANCELLED` showed up repeatedly for users on
	# arab.place). Chrome reports those resets as ERR_ABORTED with
	# a synthetic 500 status, which trips SvelteKit's preloadCss
	# helper and renders +error.svelte instead of the real route.
	# HTTP/2 is fine for this site.
	servers {
		protocols h1 h2
	}
}

# `alt-svc: clear` revokes any HTTP/3 advertisement the browser
# already cached (Caddy was previously sending `h3=":443"; ma=2592000`
# which sticks for 30 days). Without this, browsers keep trying QUIC
# first even though the server no longer listens on UDP 443; the
# failed QUIC handshake shows up in DevTools as `ERR_ABORTED 500` for
# preloads. Once a browser sees `alt-svc: clear` it drops the cached
# h3 endpoint and goes straight to HTTP/2.
(no-h3-altsvc) {
	header Alt-Svc clear
}

# ----- HybridSocial main domain -----
arab.place {
	# WebSocket streaming — separate from the rest so we don't break
	# long-lived connections.
	@streaming path /api/v1/streaming/*
	handle @streaming {
		reverse_proxy hs_backend:4000 {
			transport http {
				read_timeout 0
			}
		}
	}

	# ActivityPub federation paths + REST API → Phoenix
	#
	# /actor and /outbox are instance-level AP paths served by
	# InstanceActorController. Before, they fell through to
	# SvelteKit (HTML) so remote peers verifying our HTTP
	# signature couldn't fetch the instance actor's publicKeyPem,
	# and relay Accept activities POSTed to /inbox got a 404.
	@api path /api/* /.well-known/* /nodeinfo/* /actor /actor/* /inbox /outbox /users/* /actors/* /activities/* /oauth/* /media/* /uploads/* /proxy/media/* /posts/* /dm/*
	handle @api {
		reverse_proxy hs_backend:4000
	}

	# Server-rendered OG/Twitter Card shells for social-sharing
	# crawlers. These bots don't run JS, so the SPA shell that
	# SvelteKit serves has no OG metadata and they can't unfurl
	# our /post/:id, /@:handle, /legal/:slug URLs into rich
	# previews. Phoenix's CrawlerController fills that in — but
	# only sees the request when Caddy routes it to the backend.
	# Match on User-Agent so real browsers stay on the SPA bundle
	# (CrawlerController's `send_spa_handoff` redirect would add
	# a visible flash for them). Sitemap + robots paths go to
	# backend unconditionally since the SPA has no business
	# serving them.
	@bot_unfurl {
		path /post/* /@* /legal/*
		header_regexp User-Agent (?i)(facebookexternalhit|facebot|twitterbot|linkedinbot|slackbot|slack-imgproxy|whatsapp|telegrambot|telegram|discordbot|skypeuripreview|redditbot|pinterest|bingbot|googlebot|google-structured-data-testing-tool|yandexbot|duckduckbot|applebot|baiduspider|archive\.org_bot|bitlybot|mastodon|pleroma|misskey|akkoma|iframely|embedly|lightbot|signal|xing-contenttabreceiver|vkshare|w3c_validator|hybridsocial)
	}
	handle @bot_unfurl {
		reverse_proxy hs_backend:4000
	}

	@seo path /robots.txt /sitemap.xml /sitemap/*
	handle @seo {
		reverse_proxy hs_backend:4000
	}

	# Everything else → SvelteKit
	handle {
		reverse_proxy hs_frontend:3000
	}

	# SvelteKit HTML pages (everything that's not a hashed asset) must
	# NEVER be cached by browsers. The HTML embeds the current build's
	# asset hashes, so a cached HTML from a previous deploy points to
	# chunks that no longer exist and the page silently breaks (DevTools
	# shows a wave of 404s on /_app/immutable/chunks/<old-hash>.js and
	# the SvelteKit error page rendering at status 500 because preload
	# links fail). The /_app/immutable/* assets are content-hashed so
	# they stay cacheable forever (SvelteKit already sets
	# `cache-control: public, max-age=31536000, immutable` on them).
	@html_pages {
		not path /_app/immutable/*
		not path /uploads/*
		not path /icons/*
		not path /sounds/*
		not path /badges/*
		not path /images/*
		not path /manifest.json
		not path /sw.js
		not path /favicon*
	}
	header @html_pages Cache-Control "no-store, must-revalidate"

	# Strip SvelteKit's `Link: <...>; rel=preload` early-hint header.
	# SvelteKit's JS bundle ALSO calls a runtime preload helper that
	# adds `<link rel=preload>` for the same URLs at hydration time.
	# The duplicate triggers Chrome's de-dup optimisation: the second
	# preload is aborted, the link's `error` event fires, SvelteKit
	# treats that as a fatal navigation error and renders the 500
	# +error.svelte page (the "Unable to preload CSS" message). The
	# JS-side preload is sufficient on its own — strip the header
	# version so only one preload exists per asset.
	header @html_pages -Link

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}

	encode gzip zstd

	log {
		output file /data/access-arab.log {
			roll_size 50mb
			roll_keep 3
		}
		format json
	}
}

# ----- HybridSocial media domain -----
# Separate origin for user uploads — keeps cookies + scripts off the
# media path so a hostile upload can't piggyback on the main site.
media.arab.place {
	# CORS for user uploads. The main site (arab.place) needs to
	# fetch() audio attachments from this origin to generate the
	# waveform visualization in the Web Audio API. Cross-origin
	# GET of an <img>/<audio> element works without CORS (opaque
	# response); decoding the bytes in JS does not.
	header {
		X-Content-Type-Options nosniff
		Content-Security-Policy "default-src 'none'; img-src 'self'; media-src 'self'; style-src 'none'; script-src 'none'"
		X-Frame-Options DENY
		-Server
		-Set-Cookie
	}

	handle /uploads/* {
		header Access-Control-Allow-Origin "https://arab.place"
		header Access-Control-Allow-Methods "GET"
		header Vary "Origin"
		reverse_proxy hs_backend:4000
	}

	handle /proxy/media/* {
		header Access-Control-Allow-Origin "https://arab.place"
		header Access-Control-Allow-Methods "GET"
		header Vary "Origin"
		reverse_proxy hs_backend:4000
	}

	handle {
		respond "Not Found" 404
	}

	encode gzip zstd
}

# ----- Mastodon main domain -----
mastodon.arab.place {
	# Streaming API → mastodon_streaming (port 4000 inside container)
	@streaming path /api/v1/streaming/*
	handle @streaming {
		reverse_proxy mastodon_streaming:4000
	}

	# Everything else → mastodon_web (puma, port 3000)
	handle {
		reverse_proxy mastodon_web:3000
	}

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}

	# Mastodon serves uploaded media itself but enable compression for
	# the HTML / JSON responses.
	encode gzip zstd

	log {
		output file /data/access-mastodon.log {
			roll_size 50mb
			roll_keep 3
		}
		format json
	}
}

# ----- Mastodon media reservation -----
# Cert provisioned now so a future Mastodon S3 split has TLS ready.
# Today Mastodon serves its own media off mastodon.arab.place; this
# block 404s anything that hits it directly.
media-mastodon.arab.place {
	respond "Not configured" 404
	header -Server
}
